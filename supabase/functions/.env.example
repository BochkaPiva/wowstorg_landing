# Local Edge Function development only. Copy to .env.local and never commit real values.
ALLOWED_ORIGINS=http://127.0.0.1:5202,http://localhost:5202
TURNSTILE_SECRET_KEY=REPLACE_WITH_CLOUDFLARE_SECRET_KEY
IP_HASH_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOTFATHER_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_INTERNAL_GROUP_CHAT_ID
# Optional. Set this when notifications must go to a specific forum topic.
TELEGRAM_MESSAGE_THREAD_ID=REPLACE_WITH_TOPIC_ID
CRON_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES
